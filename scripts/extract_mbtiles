#!/usr/bin/env python3

from multiprocessing import Pool
from pathlib import Path
from PIL import Image
import threading
import argparse
import sqlite3
import hashlib
import logging
import signal
import uuid
import time
import math
import json
import sys
import io


# ========= LOG =========
LOGGER = logging.getLogger(__name__)
handler = logging.StreamHandler()
handler.setFormatter(logging.Formatter("%(asctime)s %(levelname)5s: %(message)s"))
LOGGER.addHandler(handler)
LOGGER.setLevel(logging.INFO)


# ========= CONSTANTS =========
SPHERICAL_RADIUS = 6378137.0
MAX_LON = 180
MAX_LAT = 90
MAX_CAL_LAT = 85.051129


# ========= SIGNALS =========
def setup_signals():
	signal.signal(signal.SIGINT, lambda sig, frame: (
		LOGGER.info("Received 'SIGINT' signal. Exitting..."),

		sys.exit(0)
	))

	signal.signal(signal.SIGTERM, lambda sig, frame: (
		LOGGER.info("Received 'SIGTERM' signal. Exitting..."),

		sys.exit(0)
	))


# ========= COMMAND =========
def setup_command():
	parser = argparse.ArgumentParser(description="Extract MBTiles")
	parser.add_argument("-o", "--output", required=True, type=Path, help="Output MBTiles file path")
	parser.add_argument("-w", "--workers", required=False, type=int, default=1, help="Number of worker processes")
	parser.add_argument("-bz", "--batch_size", required=False, type=int, default=1000, help="Batch size")
	parser.add_argument("-mi", "--metadata-index", required=False, action="store_true", help="Create metadata unique index")
	parser.add_argument("-ti", "--tiles-index", required=False, action="store_true", help="Create tiles unique index")
	parser.add_argument("-ei", "--extra-info", required=False, action="store_true", help="Create extra info in tiles table (hash and created columns)")
	parser.add_argument("-md", "--merge-delete", required=False, action="store_true", help="Delete input MBtiles after merge")
	parser.add_argument("-ms", "--merge-strategy", required=False, choices=["overwrite", "keep", "merge"], default="overwrite", help="Merge strategy")
	parser.add_argument("-c", "--compression", required=False, action="store_true", help="Enable compression tile for output MBTiles")
	parser.add_argument("-ovr", "--overview", required=False, action="store_true", help="Create overview for output MBTiles")
	parser.add_argument("-r", "--resampling", required=False, choices=["nearest", "bilinear", "cubic", "lanczos"], default="lanczos", help="Resampling method to create overview")

	input_group = parser.add_mutually_exclusive_group(required=False)
	input_group.add_argument("-i", "--inputs", nargs="+", type=Path, help="Input MBTiles file paths")
	input_group.add_argument("-il", "--inputs-list", type=Path, help="Text file path containing input MBTiles file paths (one per line)")

	metadata_group = parser.add_mutually_exclusive_group(required=False)
	metadata_group.add_argument("-mj", "--metadata-json", type=str, help="Metadata JSON string to update metadata table")
	metadata_group.add_argument("-mf", "--metadata-json-file", type=Path, help="Metadata JSON file path to update metadata table")

	return parser


# ========= UTILS =========
def parse_bounds(bounds):
	parts = bounds.split(",")

	if len(parts) != 4:
		raise ValueError(f"Invalid bounds format '{bounds}'")

	bounds = [float(x) for x in parts]

	if bounds[0] >= bounds[2] or bounds[0] < -MAX_LON or bounds[2] > MAX_LON or bounds[1] >= bounds[3] or bounds[1] < -MAX_LAT or bounds[3] > MAX_LAT:
		raise ValueError(f"Invalid bounds values '{bounds}'")

	return bounds


def encode_array(bounds):
	return ",".join(str(x) for x in bounds)


def limit_value(value, min = None, max = None):
	if min is not None and value < min:
		value = min

	if max is not None and value > max:
		value = max

	return value


def lonlat4326_to_xy3857(lon, lat):
	return limit_value(lon, -MAX_LON, MAX_LON) * math.pi / MAX_LON * SPHERICAL_RADIUS, math.log(math.tan(math.pi * (limit_value(lat, -MAX_CAL_LAT, MAX_CAL_LAT) + MAX_LAT) / (2 * MAX_LON))) * SPHERICAL_RADIUS


def xy3857_to_lonlat4326(x, y):
	return limit_value(x / SPHERICAL_RADIUS * MAX_LON / math.pi, -MAX_LON, MAX_LON), limit_value(math.atan(math.sinh(y / SPHERICAL_RADIUS)) * MAX_LON / math.pi, -MAX_CAL_LAT, MAX_CAL_LAT)


def get_xyz_from_lonlatz(lon, lat, z, scheme="tms"):
	max_tile = 1 << z

	x = (0.5 + limit_value(lon, -MAX_LON, MAX_LON) / (2 * MAX_LON)) * max_tile
	y = (0.5 - math.log(math.tan(math.pi * (limit_value(lat, -MAX_CAL_LAT, MAX_CAL_LAT) + MAX_LAT) / (2 * MAX_LON))) / (2 * math.pi)) * max_tile

	if scheme == "tms":
		y = max_tile - y

	return [limit_value(math.floor(x), 0, max_tile - 1), limit_value(math.floor(y), 0, max_tile - 1), z]


def get_lonlatz_from_xyz(x, y, z, position, scheme="tms"):
	max_tile = 1 << z

	if scheme == "tms":
		y = max_tile - 1 - y

	if position == "center":
		x += 0.5
		y += 0.5
	elif position == "bottom-right":
		x += 1
		y += 1

	return [(2 * MAX_LON) * (x / max_tile - 0.5), ((2 * MAX_LON) * math.atan(math.exp(math.pi * (1 - 2 * y / max_tile))) / math.pi) - MAX_LAT, z]


def get_tile_bounds_4326(x, y, z, scheme="tms"):
	[min_lon, max_lat, _] = get_lonlatz_from_xyz(x, y, z, "top-left", scheme)
	[max_lon, min_lat, _] = get_lonlatz_from_xyz(x, y, z, "bottom-right", scheme)

	return [min_lon, min_lat, max_lon, max_lat]


def get_tile_bounds_3857(x, y, z, scheme="tms"):
	[min_lon, max_lat, _] = get_lonlatz_from_xyz(x, y, z, "top-left", scheme)
	[max_lon, min_lat, _] = get_lonlatz_from_xyz(x, y, z, "bottom-right", scheme)

	return [*lonlat4326_to_xy3857(min_lon, min_lat), *lonlat4326_to_xy3857(max_lon, max_lat)]


def get_bbox_from_tiles(x_min, y_min, x_max, y_max, z, scheme = "tms"):
	[lon_min, lat_max, _] = get_lonlatz_from_xyz(x_min, y_min, z, "top-left", scheme)
	[lon_max, lat_min, _] = get_lonlatz_from_xyz(x_max, y_max, z, "bottom-right", scheme)

	if lon_min > lon_max:
		[lon_min, lon_max] = [lon_max, lon_min]

	if lat_min > lat_max:
		[lat_min, lat_max] = [lat_max, lat_min]

	return [lon_min, lat_min, lon_max, lat_max]


def get_tiles_from_bbox(bbox, z, scheme = "tms"):
	[x_min, y_min, _] = get_xyz_from_lonlatz(bbox[0], bbox[3], z, scheme)
	[x_max, y_max, _] = get_xyz_from_lonlatz(bbox[2], bbox[1], z, scheme)

	if x_min > x_max:
		[x_min, x_max] = [x_max, x_min]

	if y_min > y_max:
		[y_min, y_max] = [y_max, y_min]

	return [x_min, y_min, x_max, y_max]


def get_cover_bbox(bbox1, bbox2):
	if bbox1 and bbox2:
		return [
			bbox1[0] if bbox1[0] < bbox2[0] else bbox2[0],
			bbox1[1] if bbox1[1] < bbox2[1] else bbox2[1],
			bbox1[2] if bbox1[2] > bbox2[2] else bbox2[2],
			bbox1[3] if bbox1[3] > bbox2[3] else bbox2[3],
		]
	elif bbox1:
		return bbox1
	elif bbox2:
		return bbox2

	return None


def get_intersect_bbox(bbox1, bbox2):
	if bbox1 and bbox2:
		minLon = bbox1[0] if bbox1[0] > bbox2[0] else bbox2[0]
		minLat = bbox1[1] if bbox1[1] > bbox2[1] else bbox2[1]
		maxLon = bbox1[2] if bbox1[2] < bbox2[2] else bbox2[2]
		maxLat = bbox1[3] if bbox1[3] < bbox2[3] else bbox2[3]

		if (minLon >= maxLon or minLat >= maxLat):
			return None
	elif bbox1:
		return bbox1
	elif bbox2:
		return bbox2

	return None


def process_tile(args):
	z, x, y, tile_data, save_args = args

	out = io.BytesIO()

	Image.open(io.BytesIO(tile_data)).convert("RGBA").save(out, **save_args)

	return z, x, y, out.getvalue()


def composite_tile(args):
	z, x, y, new_data, old_data, save_args = args

	out = io.BytesIO()

	new_img = Image.open(io.BytesIO(new_data)).convert("RGBA")

	if old_data:
		Image.alpha_composite(Image.open(io.BytesIO(old_data)).convert("RGBA"), new_img).save(out, **save_args)
	else:
		new_img.save(out, **save_args)

	return z, x, y, out.getvalue()


def build_parent_tile(args):
	p_z, p_x, p_y, childrens, build_args = args

	min_c_x = p_x * 2
	min_c_y = p_y * 2
	max_c_y = min_c_y + 1

	out = io.BytesIO()

	canvas = Image.new(*build_args["background_args"])

	for cx, cy, cdata in childrens:
		canvas.alpha_composite(
			Image.open(io.BytesIO(cdata)).convert("RGBA"),
			(
				(cx - min_c_x) * build_args["tile_size"],
				(cy - min_c_y if build_args["is_flip"] else max_c_y - cy) * build_args["tile_size"],
			)
		)

	canvas.resize(*build_args["resize_args"]).save(out, **build_args["save_args"])

	return p_z, p_x, p_y, out.getvalue()


def hash_tile(args):
	z, x, y, tile_data, created = args

	return hashlib.md5(tile_data).hexdigest(), created, z, x, y


# ========= MBTILES =========
def get_mbtiles_metadata(cur, name):
	if name is not None:
		cur.execute("SELECT name, value FROM metadata WHERE name = ?;", (name,))
		row = cur.fetchone()
		if row:
			return row[1]


def get_mbtiles_metadatas(cur):
	cur.execute("SELECT name, value FROM metadata;")
	rows = cur.fetchall()
	if rows:
		return { name: value for name, value in rows }


def get_mbtiles_bounds_from_tiles(cur, scheme="tms"):
	cur.execute("SELECT zoom_level, MIN (tile_column), MAX (tile_column), MIN (tile_row), MAX (tile_row) FROM tiles GROUP BY zoom_level;")
	rows = cur.fetchall()
	if not rows:
		return None

	z, x_min, x_max, y_min, y_max = rows[0]
	bounds = get_bbox_from_tiles(x_min, y_min, x_max, y_max, z, scheme)

	if len(rows) > 1:
		for row in rows[1:]:
			z, x_min, x_max, y_min, y_max = row

			bounds = get_cover_bbox(bounds, get_bbox_from_tiles(x_min, y_min, x_max, y_max, z, scheme))

	bounds[0] = limit_value(bounds[0], -MAX_LON, MAX_LON)
	bounds[2] = limit_value(bounds[2], -MAX_LON, MAX_LON)
	bounds[1] = limit_value(bounds[1], -MAX_CAL_LAT, MAX_CAL_LAT)
	bounds[3] = limit_value(bounds[3], -MAX_CAL_LAT, MAX_CAL_LAT)

	return bounds


def get_mbtiles_zoom_level_from_tiles(cur, min):
	if min:
		cur.execute("SELECT MIN (zoom_level) FROM tiles;")
	else:
		cur.execute("SELECT MAX (zoom_level) FROM tiles;")

	row = cur.fetchone()
	if not row:
		return None

	return row[0]


def get_mbtiles_format_from_tiles(cur):
	cur.execute("SELECT tile_data FROM tiles LIMIT 1;")
	row = cur.fetchone()
	if not row:
		return None

	if row[0].startswith(b"\x89PNG\r\n\x1a\n"):
		return "png"
	elif row[0].startswith(b"\xff\xd8"):
		return "jpeg"
	elif row[0].startswith((b"GIF87a", b"GIF89a")):
		return "gif"
	elif row[0].startswith(b"RIFF") and row[0][8:12] == b"WEBP":
		return "webp"
	else:
		return "pbf"


def get_mbtiles_tile_size_from_tiles(cur):
	cur.execute("SELECT tile_data FROM tiles LIMIT 1;")
	row = cur.fetchone()
	if not row:
		return None

	return Image.open(io.BytesIO(row[0])).width


# ======== CONNECT MBTILES =========
def connect(file_path, ensure_schema = None):
	conn = sqlite3.connect(file_path)
	cur = conn.cursor()

	cur.execute("PRAGMA journal_mode = OFF;")
	cur.execute("PRAGMA synchronous = OFF;")
	cur.execute("PRAGMA foreign_keys = OFF;")
	cur.execute("PRAGMA encoding = 'UTF-8';")
	cur.execute("PRAGMA page_size = 65536;")

	if ensure_schema:
		cur.execute("CREATE TABLE IF NOT EXISTS metadata (name TEXT NOT NULL, value TEXT NOT NULL, UNIQUE (name));")
		cur.execute("CREATE TABLE IF NOT EXISTS tiles (zoom_level INTEGER NOT NULL, tile_column INTEGER NOT NULL, tile_row INTEGER NOT NULL, tile_data BLOB NOT NULL, UNIQUE (zoom_level, tile_column, tile_row));")

	return conn, cur


# ======== MOVE AND CONNECT MBTILES =========
def move_and_connect(file_path, compression, workers, batch_size):
	src_conn, src_cur = connect(file_path)

	tile_format = get_mbtiles_metadata(src_cur, "format")
	if tile_format is None:
		tile_format = get_mbtiles_format_from_tiles(src_cur)

	src_conn.close()

	if tile_format:
		insert_query = "INSERT INTO tiles (zoom_level, tile_column, tile_row, tile_data) VALUES (?, ?, ?, ?);"
		select_query = "SELECT src.rowid, src.zoom_level, src.tile_column, src.tile_row, src.tile_data FROM src.tiles src WHERE src.rowid > ? ORDER BY src.rowid LIMIT ?;"

		last_rowid = 0

		save_args = {
			"format": tile_format.upper(),
			"optimize": True,
			"lossless": True,
			"quality": 100,
		}
		if compression:
			save_args.update({
				"compress_level": 9,
				"method": 6,
				"subsampling": 2,
			})

		# Create workers
		if workers > 1:
			pool = Pool(workers)
		else:
			pool = None

		tmp_file_path = file_path.with_name(f"{file_path.stem}_{uuid.uuid4().hex}{file_path.suffix}")

		conn, cur = connect(tmp_file_path, True)

		cur.execute("ATTACH DATABASE ? AS src;", (str(file_path),))

		conn.execute("BEGIN;")

		try:
			if tile_format == "pbf":
				while True:
					cur.execute(select_query, (last_rowid, batch_size))
					rows = cur.fetchall()
					if not rows:
						break

					for _, z, x, y, tile_data in rows:
						cur.execute(insert_query, (z, x, y, tile_data))

					last_rowid = rows[-1][0]
			else:
				while True:
					cur.execute(select_query, (last_rowid, batch_size))
					rows = cur.fetchall()
					if not rows:
						break

					if pool:
						for data in pool.imap_unordered(process_tile, [(z, x, y, tile_data, save_args) for _, z, x, y, tile_data in rows]):
							cur.execute(insert_query, data)
					else:
						for _, z, x, y, tile_data in rows:
							cur.execute(insert_query, process_tile((z, x, y, tile_data, save_args)))

					last_rowid = rows[-1][0]
		finally:
			if pool:
				pool.close()
				pool.join()

		conn.execute("COMMIT;")

		cur.execute("DETACH DATABASE src;")

		conn.close()

	tmp_file_path.replace(file_path)

	return connect(file_path)


# ======== CREATE MBTILES UNIQUE INDEXES =========
def create_unique_indexes(cur, metadata_index, tiles_index):
	def has_unique_index(table_name, column_names):
		cur.execute(f"PRAGMA index_list ({table_name});")
		indexes = cur.fetchall()
		if not indexes:
			return False

		for _, index_name, is_unique, *_ in indexes:
			if not is_unique:
				continue

			cur.execute(f"PRAGMA index_info ({index_name});")
			columns = cur.fetchall()
			if not columns:
				continue

			index_cols = [col[2] for col in columns]
			if index_cols == column_names:
				return True

		return False

	if metadata_index and not has_unique_index("metadata", ["name"]):
		cur.execute("CREATE UNIQUE INDEX metadata_index ON metadata (name);")

	if tiles_index and not has_unique_index("tiles", ["zoom_level", "tile_column", "tile_row"]):
		cur.execute("CREATE UNIQUE INDEX tiles_index ON tiles (zoom_level, tile_column, tile_row);")


# ========= MERGE MBTILESES =========
def merge(conn, cur, inputs, merge_strategy, merge_delete, compression, workers, batch_size, metadata_json):
	final_bounds = None
	limit_bounds = None
	tile_format = "png"
	scheme = "tms"

	if metadata_json:
		if "bounds" in metadata_json:
			limit_bounds = parse_bounds(metadata_json["bounds"])

		if "format" in metadata_json:
			tile_format = metadata_json["format"]

		if "scheme" in metadata_json:
			scheme = metadata_json["scheme"]

	insert_query = None
	select_query = None
	if merge_strategy == "overwrite":
		insert_query = "INSERT OR REPLACE INTO tiles (zoom_level, tile_column, tile_row, tile_data) VALUES (?, ?, ?, ?);"
		select_query = "SELECT src.rowid, src.zoom_level, src.tile_column, src.tile_row, src.tile_data FROM src.tiles src WHERE src.rowid > ? ORDER BY src.rowid LIMIT ?;"
	elif merge_strategy == "keep":
		insert_query = "INSERT OR IGNORE INTO tiles (zoom_level, tile_column, tile_row, tile_data) VALUES (?, ?, ?, ?);"
		select_query = "SELECT src.rowid, src.zoom_level, src.tile_column, src.tile_row, src.tile_data FROM src.tiles src WHERE src.rowid > ? ORDER BY src.rowid LIMIT ?;"
	else:
		if tile_format == "pbf":
			raise ValueError(f"Strategy '{merge_strategy}' is not support with format '{tile_format}'")

		insert_query = "INSERT OR REPLACE INTO tiles (zoom_level, tile_column, tile_row, tile_data) VALUES (?, ?, ?, ?);"
		select_query = "SELECT src.rowid, src.zoom_level, src.tile_column, src.tile_row, src.tile_data AS new_data, dst.tile_data AS old_data FROM src.tiles src LEFT JOIN tiles dst ON dst.zoom_level = src.zoom_level AND dst.tile_column = src.tile_column AND dst.tile_row = src.tile_row WHERE src.rowid > ? ORDER BY src.rowid LIMIT ?;"

	save_args = {
		"format": tile_format.upper(),
		"optimize": True,
		"lossless": True,
		"quality": 100,
	}
	if compression:
		save_args.update({
			"compress_level": 9,
			"method": 6,
			"subsampling": 2,
		})

	# Create workers
	if workers > 1:
		pool = Pool(workers)
	else:
		pool = None

	try:
		for idx, path in enumerate(inputs):
			last_rowid = 0

			LOGGER.info(f"Merging '{path}' - {idx + 1}...")

			src_conn = sqlite3.connect(path, False)
			src_cur = src_conn.cursor()

			src_bounds = get_mbtiles_metadata(src_cur, "bounds")
			if src_bounds:
				src_bounds = parse_bounds(src_bounds)
			else:
				src_bounds = get_mbtiles_bounds_from_tiles(src_cur, scheme)

				if limit_bounds and get_intersect_bbox(limit_bounds, src_bounds) is None:
					LOGGER.warning(f"Skipping outside MBTiles '{path}' - {idx + 1}...")

					src_conn.close()

					if merge_delete:
						path.unlink(missing_ok=True)

					continue

			src_conn.close()

			final_bounds = get_cover_bbox(final_bounds, src_bounds)

			cur.execute("ATTACH DATABASE ? AS src;", (str(path),))

			conn.execute("BEGIN;")

			if merge_strategy == "overwrite" or merge_strategy == "keep":
				if tile_format == "pbf":
					while True:
						cur.execute(select_query, (last_rowid, batch_size))
						rows = cur.fetchall()
						if not rows:
							break

						for _, z, x, y, tile_data in rows:
							cur.execute(insert_query, (z, x, y, tile_data))

						last_rowid = rows[-1][0]
				else:
					while True:
						cur.execute(select_query, (last_rowid, batch_size))
						rows = cur.fetchall()
						if not rows:
							break

						if pool:
							for data in pool.imap_unordered(process_tile, [(z, x, y, tile_data, save_args) for _, z, x, y, tile_data in rows]):
								cur.execute(insert_query, data)
						else:
							for _, z, x, y, tile_data in rows:
								cur.execute(insert_query, process_tile((z, x, y, tile_data, save_args)))

						last_rowid = rows[-1][0]
			else:
				while True:
					cur.execute(select_query, (last_rowid, batch_size))
					rows = cur.fetchall()
					if not rows:
						break

					if pool:
						for data in pool.imap_unordered(composite_tile, [(z, x, y, new_data, old_data, save_args) for _, z, x, y, new_data, old_data in rows]):
							cur.execute(insert_query, data)
					else:
						for _, z, x, y, new_data, old_data in rows:
							cur.execute(insert_query, composite_tile((z, x, y, new_data, old_data, save_args)))

					last_rowid = rows[-1][0]

			conn.execute("COMMIT;")

			cur.execute("DETACH DATABASE src;")

			if merge_delete:
				path.unlink(missing_ok=True)
	finally:
		if pool:
			pool.close()
			pool.join()

	return get_intersect_bbox(limit_bounds, final_bounds)


# ========= UPDATE MBTILES METADATA =========
def update_metadata(conn, cur, metadata_json, merge_bounds, ovr_minzoom):
	final_metadata = {}

	origin_metadatas = get_mbtiles_metadatas(cur)
	if origin_metadatas:
		final_metadata.update(origin_metadatas)

	if merge_bounds:
		if "bounds" in final_metadata:
			final_metadata["bounds"] = encode_array(get_cover_bbox(parse_bounds(final_metadata["bounds"]), merge_bounds))
		else:
			final_metadata["bounds"] = encode_array(merge_bounds)

	if ovr_minzoom is not None:
		if "minzoom" in final_metadata:
			final_metadata["minzoom"] = str(min(int(final_metadata["minzoom"]), ovr_minzoom))
		else:
			final_metadata["minzoom"] = str(ovr_minzoom)

	if metadata_json:
		final_metadata.update(metadata_json)

	if "name" not in final_metadata:
		final_metadata["name"] = "Unknown"

	if "description" not in final_metadata:
		final_metadata["description"] = final_metadata["name"]

	if "attribution" not in final_metadata:
		final_metadata["attribution"] = "<b>Viettel HighTech</b>"

	if "version" not in final_metadata:
		final_metadata["version"] = "1.0.0"

	if "type" not in final_metadata:
		final_metadata["type"] = "overlay"

	if "format" not in final_metadata:
		tile_format = get_mbtiles_format_from_tiles(cur)
		if tile_format is not None:
			final_metadata["format"] = tile_format

	minzoom = None
	if "minzoom" not in final_metadata:
		minzoom = get_mbtiles_zoom_level_from_tiles(cur, True)
		if minzoom is not None:
			final_metadata["minzoom"] = str(minzoom)

	maxzoom = None
	if "maxzoom" not in final_metadata:
		maxzoom = get_mbtiles_zoom_level_from_tiles(cur, False)
		if maxzoom is not None:
			final_metadata["maxzoom"] = str(maxzoom)

	if "scheme" not in final_metadata:
		final_metadata["scheme"] = "tms"

	bounds = None
	if "bounds" not in final_metadata:
		bounds = get_mbtiles_bounds_from_tiles(cur, final_metadata["scheme"])
		if bounds:
			final_metadata["bounds"] = encode_array(bounds)
	else:
		bounds = parse_bounds(final_metadata["bounds"])

	if "center" not in final_metadata:
		if bounds and minzoom is not None and maxzoom is not None:
			final_metadata["center"] = encode_array([(bounds[0] + bounds[2]) / 2, (bounds[1] + bounds[3]) / 2, math.floor((minzoom + maxzoom) / 2)])

	insert_query = "INSERT INTO metadata (name, value) VALUES (?, ?) ON CONFLICT (name) DO UPDATE SET value = excluded.value;"

	conn.execute("BEGIN;")

	for key, value in final_metadata.items():
		cur.execute(insert_query, (key, value))

	conn.execute("COMMIT;")


# ========= CREATE MBTILES OVERVIEW =========
def create_overview(conn, cur, resampling, compression, workers, batch_size, metadata_json):
	tile_format = "png"
	tile_size = 256
	scheme = "tms"
	is_flip = None
	maxzoom = None

	if metadata_json:
		if "format" in metadata_json:
			tile_format = metadata_json["format"]

		if "tile_size" in metadata_json:
			tile_size = int(metadata_json["tile_size"])

		if "scheme" in metadata_json:
			scheme = metadata_json["scheme"]

	if tile_format == "pbf":
		raise ValueError(f"Overview is not support with format '{tile_format}'")

	metadatas = get_mbtiles_metadatas(cur)
	if metadatas:
		if "scheme" in metadatas:
			is_flip = metadatas["scheme"] != scheme

		if "maxzoom" in metadatas:
			maxzoom = int(metadatas["maxzoom"])

	if maxzoom is None:
		maxzoom = get_mbtiles_zoom_level_from_tiles(cur, False)
		if maxzoom is None:
			raise ValueError(f"Unknown maxzoom")

	insert_query = "INSERT OR REPLACE INTO tiles (zoom_level, tile_column, tile_row, tile_data) VALUES (?, ?, ?, ?);"
	select_p_query = "SELECT DISTINCT tile_column / 2 as p_x, tile_row / 2 as p_y FROM tiles WHERE zoom_level = ? AND (tile_column / 2 > ? OR (tile_column / 2 = ? AND tile_row / 2 > ?)) ORDER BY p_x, p_y LIMIT ?;"
	select_c_range_query = "SELECT tile_column, tile_row, tile_data FROM tiles WHERE zoom_level = ? AND tile_column BETWEEN ? AND ? AND tile_row BETWEEN ? AND ?;"

	build_args = {
		"save_args": {
			"format": tile_format.upper(),
			"optimize": True,
			"lossless": True,
			"quality": 100,
		},
		"is_flip": is_flip,
		"resampling": resampling,
		"tile_size": tile_size,
		"background_args": ("RGBA", (tile_size * 2, tile_size * 2), (255, 255, 255, 0)),
		"resize_args": ((tile_size, tile_size), resampling),
	}
	if compression:
		build_args["save_args"].update({
			"compress_level": 9,
			"method": 6,
			"subsampling": 2,
		})

	# Create workers
	if workers > 1:
		pool = Pool(workers)
	else:
		pool = None

	conn.execute("BEGIN;")

	try:
		while maxzoom > 0:
			created_tiles = 0

			c_zoom = maxzoom
			p_z = maxzoom - 1

			last_p = (-1, -1)

			LOGGER.info(f"Creating zoom level - {p_z}...")

			while True:
				cur.execute(select_p_query, (c_zoom, last_p[0], last_p[0], last_p[1], batch_size))
				parents = cur.fetchall()
				if not parents:
					break

				tasks = []

				for p_x, p_y in parents:
					min_c_x = p_x * 2
					max_c_x = min_c_x + 1
					min_c_y = p_y * 2
					max_c_y = min_c_y + 1

					cur.execute(select_c_range_query, (c_zoom, min_c_x, max_c_x, min_c_y, max_c_y))
					childrens = cur.fetchall()
					if not childrens:
						continue

					tasks.append((p_z, p_x, p_y, childrens, build_args))

				if pool:
					for data in pool.imap_unordered(build_parent_tile, tasks):
						cur.execute(insert_query, data)

						created_tiles += 1
				else:
					for task in tasks:
						cur.execute(insert_query, build_parent_tile(task))

						created_tiles += 1

				last_p = parents[-1]

			maxzoom = p_z

			if created_tiles <= 1:
				break
	finally:
		if pool:
			pool.close()
			pool.join()

	conn.execute("COMMIT;")

	return maxzoom


# ========= UPDATE MBTILES EXTRA INFO (HASH AND CREATED) =========
def update_hash_and_created(conn, cur, batch_size):
	def has_column(column):
		cur.execute("PRAGMA table_info (tiles);")
		rows = cur.fetchall()
		if rows:
			if column in { row[1] for row in rows }:
				return True
			else:
				return False
		else:
			raise ValueError("Cannot get 'tiles' table info")

	if not has_column("hash"):
		cur.execute("ALTER TABLE tiles ADD COLUMN hash TEXT;")

	if not has_column("created"):
		cur.execute("ALTER TABLE tiles ADD COLUMN created BIGINT;")

	created = int(time.time() * 1000)

	select_query = "SELECT rowid, zoom_level, tile_column, tile_row, tile_data FROM tiles WHERE rowid > ? ORDER BY rowid LIMIT ?;"
	update_query = "UPDATE tiles SET hash = ?, created = ? WHERE zoom_level = ? AND tile_column = ? AND tile_row = ?;"

	last_rowid = 0

	# Create workers
	if workers > 1:
		pool = Pool(workers)
	else:
		pool = None

	conn.execute("BEGIN;")

	try:
		while True:
			cur.execute(select_query, (last_rowid, batch_size))
			rows = cur.fetchall()
			if not rows:
				break

			if pool:
				for data in pool.imap_unordered(hash_tile, [(z, x, y, tile_data, created) for _, z, x, y, tile_data in rows]):
					cur.execute(update_query, data)
			else:
				for _, z, x, y, tile_data in rows:
					cur.execute(update_query, hash_tile((z, x, y, tile_data, created)))

			last_rowid = rows[-1][0]
	finally:
		if pool:
			pool.close()
			pool.join()

	conn.execute("COMMIT;")


# ========= MAIN =========
if __name__ == "__main__":
	if threading.current_thread() is threading.main_thread():
		setup_signals()

	parser = setup_command()

	args = parser.parse_args()

	# Parse and validate metadata json
	metadata_json = None
	if args.metadata_json:
		try:
			metadata_json = json.loads(args.metadata_json)
		except Exception as e:
			raise ValueError(f"Invalid Metadata JSON string {e}")
	elif args.metadata_json_file:
		if not args.metadata_json_file.exists():
			raise FileNotFoundError(f"Metadata JSON file not found '{args.metadata_json_file}'")

		try:
			with open(args.metadata_json_file, "r", encoding="utf-8") as f:
				metadata_json = json.load(f)
		except Exception as e:
			raise ValueError(f"Invalid Metadata JSON file {e}")

	if args.metadata_json:
		metadata_json = json.loads(args.metadata_json)
		if not isinstance(metadata_json, dict):
			raise ValueError("Metadata JSON must be an object")

	# Parse and validate input MBTiles file paths
	inputs = []
	if args.inputs:
		inputs = args.inputs
	elif args.inputs_list:
		if not args.inputs_list.exists():
			raise FileNotFoundError(f"Input MBTiles files list not found '{args.inputs_list}'")

		with open(args.inputs_list, "r", encoding="utf-8") as f:
			for line in f:
				line = line.strip()
				if line:
					inputs.append(Path(line))

	for input in inputs:
		if not input.exists():
			raise FileNotFoundError(f"Input MBTiles file not found '{input}'")

	# Parse resampling
	resampling = Image.LANCZOS
	if args.resampling == "nearest":
		resampling = Image.NEAREST
	elif args.resampling == "bilinear":
		resampling = Image.BILINEAR
	elif args.resampling == "bicubic":
		resampling = Image.BICUBIC

	workers = max(1, args.workers)

	conn = None
	cur = None

	LOGGER.info(f"Extracting MBTiles '{args.output}'...")

	t0 = time.time()

	if args.output.exists():
		LOGGER.info(f"Existing output. Moving MBTiles '{args.output}'...")

		t1 = time.time()

		conn, cur = move_and_connect(args.output, args.compression, workers, args.batch_size)

		LOGGER.info(f"Moved MBTiles '{args.output}' in {time.time() - t1:.2f}s!")
	else:
		conn, cur = connect(args.output, True)

	if args.metadata_index or args.tiles_index:
		LOGGER.info(f"Creating indexes MBTiles '{args.output}'...")

		create_unique_indexes(cur, args.metadata_index, args.tiles_index)

	merge_bounds = None
	if inputs:
		LOGGER.info(f"Merging MBTiles '{args.output}'...")

		t2 = time.time()

		merge_bounds = merge(conn, cur, inputs, args.merge_strategy, args.merge_delete, args.compression, workers, args.batch_size, metadata_json)

		LOGGER.info(f"Merged MBTiles '{args.output}' in {time.time() - t2:.2f}s!")

	ovr_minzoom = None
	if args.overview:
		LOGGER.info(f"Creating overview MBTiles '{args.output}'...")

		t3 = time.time()

		ovr_minzoom = create_overview(conn, cur, resampling, args.compression, workers, args.batch_size, metadata_json)

		LOGGER.info(f"Created overview MBTiles '{args.output}' in {time.time() - t3:.2f}s!")

	if args.extra_info:
		LOGGER.info(f"Updating MBTiles hash and created '{args.output}'...")

		t4 = time.time()

		update_hash_and_created(conn, cur, args.batch_size)

		LOGGER.info(f"Updated MBTiles hash and created '{args.output}' in {time.time() - t4:.2f}s!")

	LOGGER.info(f"Updating MBTiles metadata '{args.output}'...")

	update_metadata(conn, cur, metadata_json, merge_bounds, ovr_minzoom)

	conn.close()

	LOGGER.info(f"Extracted MBTiles '{args.output}' in {time.time() - t0:.2f}s!")
